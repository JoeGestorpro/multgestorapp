{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        },
        "stitch": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://stitch.googleapis.com/mcp"
            ],
            "env": {
                "X-Goog-Api-Key": "${STITCH_API_KEY}"
            }
        }
        //other mcp servers
    }
}
// setup mcp server in  ~/.gemini\antigravity\mcp_config.json