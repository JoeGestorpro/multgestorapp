# JoeFelipe Agent — variaveis de ambiente (LLM Core)
#
# Copie para um arquivo .env local (nunca commitado — ver .gitignore) e
# preencha com valores reais somente se for ativar um provider de LLM real.
# Nenhuma chave real deve ser colocada neste arquivo de exemplo.

# Provider de LLM a ativar. Esta e a UNICA fonte de decisao explicita para
# usar um provider real — sem esta variavel (ausente ou invalida), o agente
# SEMPRE usa o MockProvider (nenhuma chamada externa), mesmo que uma chave
# esteja configurada em outra variavel abaixo.
# Valores aceitos: mock | openrouter | nvidia | openai | anthropic | local
# Hoje so "openrouter" e "nvidia" tem provider real conectado; openai/
# anthropic/local sao aceitos na validacao mas caem no MockProvider (nao
# implementados).
JOEFELIPE_LLM_PROVIDER=mock

# Chave da API OpenRouter (https://openrouter.ai/keys). So tem efeito quando
# JOEFELIPE_LLM_PROVIDER=openrouter. Nome preferido (ver tambem a variavel
# legada JOEFELIPE_OPENROUTER_API_KEY abaixo).
OPENROUTER_API_KEY=

# Nome legado da chave OpenRouter, mantido por compatibilidade com
# configuracoes anteriores. So e lido se OPENROUTER_API_KEY estiver ausente.
JOEFELIPE_OPENROUTER_API_KEY=

# Modelo do OpenRouter a usar (ex.: "openrouter/auto",
# "anthropic/claude-3.5-sonnet"). Nome preferido.
OPENROUTER_MODEL=

# Nome legado do modelo OpenRouter (mesmo racional das chaves acima).
JOEFELIPE_OPENROUTER_MODEL=

# Chave da API NVIDIA NIM (https://build.nvidia.com, formato "nvapi-...").
# So tem efeito quando JOEFELIPE_LLM_PROVIDER=nvidia. Nome preferido (ver
# tambem a variavel legada JOEFELIPE_NVIDIA_API_KEY abaixo). Nao-streaming
# nesta fase; nunca expoe reasoning/reasoning_content do modelo, so o
# content final.
NVIDIA_API_KEY=

# Nome legado da chave NVIDIA, mesmo racional de JOEFELIPE_OPENROUTER_API_KEY.
JOEFELIPE_NVIDIA_API_KEY=

# Modelo da NVIDIA a usar (default: "deepseek-ai/deepseek-v4-flash" se
# ausente). Nome preferido.
NVIDIA_MODEL=

# Nome legado do modelo NVIDIA (mesmo racional das chaves acima).
JOEFELIPE_NVIDIA_MODEL=

# Override generico de modelo, usado quando JOEFELIPE_LLM_PROVIDER nao e
# "openrouter"/"nvidia" (ex.: para os providers ainda nao implementados).
JOEFELIPE_LLM_MODEL=

# Habilita o ShellExecutor real (desabilitado por padrao — ver ShellPolicy).
# So tem efeito com o kernel em EXECUTE_APPROVED. Defina "1" para habilitar.
JOEFELIPE_SHELL_EXECUTION_ENABLED=
