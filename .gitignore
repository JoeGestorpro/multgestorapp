# Dependências
node_modules/
frontend/node_modules/
backend/node_modules/

# Variáveis de ambiente - NUNCA subir
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# EXCEÇÃO (IMPORTANTE)
!frontend/.env.production

# Permitir exemplos seguros
!.env.example
!frontend/.env.example
!backend/.env.example

# Builds
dist/
build/
frontend/dist/
frontend/build/
backend/dist/
backend/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Banco local / SQLite
*.sqlite
*.sqlite3
*.db
backend/*.sqlite
backend/*.sqlite3
backend/*.db
backend/data/
backend/database/

# Uploads/arquivos gerados
uploads/
backend/uploads/
generated/
tmp/
temp/

# Sistema operacional
.DS_Store
Thumbs.db

# VS Code
.vscode/
!.vscode/extensions.json

# Vercel / Render / cache
.vercel/
.cache/
.vercel

# OpenCode — contém credenciais, nunca commitar
opencode.json

# Cobertura de testes (artefato de build)
backend/coverage/
coverage/

# Logs de erro do backend
backend/backend.err
*.err

# Referência de design externa (repo clonado, não faz parte do projeto)
