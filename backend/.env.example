# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
# Em producao: NODE_ENV=production

# ─── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Autenticacao ────────────────────────────────────────────────────────────
JWT_SECRET=

# ─── URLs do sistema ─────────────────────────────────────────────────────────
# URL base do frontend (usada nos links de email e CORS)
# Desenvolvimento:
APP_BASE_URL=http://localhost:5173
# Producao no Vercel/Render:
# APP_BASE_URL=https://www.multgestorapp.com.br
FRONTEND_URL=http://localhost:5173
# Em producao: FRONTEND_URL=https://www.multgestorapp.com.br

# URL do proprio backend (informativa, usada em logs de validacao)
BACKEND_URL=http://localhost:5000
# Em producao: BACKEND_URL=https://<seu-servico>.onrender.com

# ─── Admin master ────────────────────────────────────────────────────────────
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=
MASTER_ADMIN_NAME=Master Admin

# ─── Email ───────────────────────────────────────────────────────────────────
# Escolha o provider: resend | smtp | mock
EMAIL_PROVIDER=smtp

# EMAIL_FROM deve conter SOMENTE o endereco de email, sem nome
EMAIL_FROM=no-reply@seudominio.com
# O nome do remetente e configurado separadamente:
EMAIL_NAME=MultGestor

TEST_EMAIL_TO=seu-email@exemplo.com

# Provider SMTP (usado quando EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@seudominio.com

# Provider Resend (usado quando EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# ─── Tokens de email ─────────────────────────────────────────────────────────
FIRST_ACCESS_TOKEN_HOURS=48
PASSWORD_RESET_TOKEN_MINUTES=60
EMAIL_VERIFICATION_TOKEN_HOURS=24

# ─── Supabase Storage (avatar de colaboradores) ──────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=barber-collaborators

# ─── Redis (opcional — rate limit distribuido e cache) ───────────────────────
# Se nao configurado, o sistema usa fallback in-memory
REDIS_URL=

# ─── Outbox worker ───────────────────────────────────────────────────────────
# Intervalo de polling do outbox em ms. Use 5000+ em producao para poupar conexoes.
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50

# ─── WhatsApp Integration ────────────────────────────────────────────────────
WHATSAPP_PROVIDER=mock
WHATSAPP_TOKEN_ENCRYPTION_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Billing / Webhooks (Kiwify) ─────────────────────────────────────────────
# Segredo compartilhado para validar o webhook da Kiwify (POST /api/webhooks/kiwify).
# OBRIGATORIO em producao: sem esta variavel o webhook retorna 500 e nenhuma
# compra ativa cliente automaticamente.
KIWIFY_WEBHOOK_SECRET=

# ─── Trial Emails ────────────────────────────────────────────────────────────
TRIAL_EMAILS_ENABLED=false

# ─── Logs ────────────────────────────────────────────────────────────────────
# Niveis: trace | debug | info | warn | error | silent
LOG_LEVEL=info

# ─── Sentry (opcional) ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Em producao: SENTRY_ENVIRONMENT=production

# ─── Debug ───────────────────────────────────────────────────────────────────
DEBUG_PLAN=false
