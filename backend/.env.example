# =============================================================================
# MultGestor — backend/.env.example
# Copie este arquivo para backend/.env e preencha os valores.
# NUNCA coloque segredos reais aqui — este arquivo é versionado.
# =============================================================================

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de dados ──────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (Transaction pooler)
DATABASE_URL=

# Role app_runtime (NOBYPASSRLS) para poolTenant.
# Se vazio, poolTenant usa DATABASE_URL e RLS fica inerte.
# Exemplo local: postgresql://app_runtime:<SUA_SENHA_AQUI>@localhost:5432/multgestor
# Exemplo Supabase: postgresql://app_runtime:<senha>@db.<ref>.supabase.co:5432/postgres
APP_RUNTIME_URL=

# CA para verificação TLS da conexão com o banco (rejectUnauthorized: true).
# Supabase → Project Settings → Database → SSL Certificate (download do .crt).
# Use UMA das duas formas; sem CA, a conexão segue sem verificação (warning no boot).
# DATABASE_SSL_CA: conteúdo PEM inline (com \n escapado)
# DATABASE_SSL_CA_PATH: caminho para o arquivo .crt
DATABASE_SSL_CA=
DATABASE_SSL_CA_PATH=

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=barber-collaborators

# ─── Autenticação ────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=

# ─── URLs do sistema ─────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# ─── Admin master ────────────────────────────────────────────────────────────
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=
MASTER_ADMIN_NAME=Master Admin

# ─── Redis (rate limit distribuído / cache) ───────────────────────────────────
# Obrigatório em produção! Sem REDIS_URL, rate limit cai para memória por-instância
# (inútil com múltiplas instâncias). Em dev, pode deixar vazio para usar fallback in-memory.
# Exemplo: redis://default:PASSWORD@host:port
REDIS_URL=

# ─── Email ───────────────────────────────────────────────────────────────────
# Escolha o provider: mock | resend | smtp
EMAIL_PROVIDER=mock
EMAIL_FROM=no-reply@seudominio.com
EMAIL_NAME=MultGestor

# Provider Resend (usado quando EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Provider SMTP (usado quando EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Tokens de email ─────────────────────────────────────────────────────────
FIRST_ACCESS_TOKEN_HOURS=48
PASSWORD_RESET_TOKEN_MINUTES=60
EMAIL_VERIFICATION_TOKEN_HOURS=24

# ─── Outbox worker ────────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50

# ─── WhatsApp / Meta Cloud API ────────────────────────────────────────────────
# Em dev: mantenha WHATSAPP_PROVIDER=mock — as variáveis META_* não são usadas.
# Em prod: troque para meta_cloud_api e preencha todas as variáveis abaixo.
WHATSAPP_PROVIDER=mock
WHATSAPP_API_VERSION=v20.0

# Chave AES-256-GCM para criptografar tokens no banco (64 chars hex)
# Gere com: openssl rand -hex 32
WHATSAPP_TOKEN_ENCRYPTION_KEY=

# ─── Meta App (obrigatório somente para meta_cloud_api) ───────────────────────
# Meta for Developers → seu app → Configurações → Básico
META_APP_ID=
META_APP_SECRET=

# Meta for Developers → WhatsApp → API Setup → Token de acesso
META_ACCESS_TOKEN=

# Token de verificação do webhook — você define (qualquer string segura)
META_VERIFY_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=

# Meta for Developers → WhatsApp → API Setup
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=

# Aliases legados (mantidos para compatibilidade com código existente)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Billing / Webhooks ───────────────────────────────────────────────────────
# Kiwify → Integrações → Webhooks → Segredo
KIWIFY_WEBHOOK_SECRET=
# AbacatePay → Configurações → Webhooks → Token
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_API_TOKEN=

# ─── Trial Emails ────────────────────────────────────────────────────────────
TRIAL_EMAILS_ENABLED=false

# ─── Appointment Reminder (WhatsApp) ────────────────────────────────────────
# Horas de antecedência para enviar o lembrete (default: 3)
REMINDER_LEAD_HOURS=3
# Intervalo do job em ms (default: 900000 = 15min). Aumente para desligar envios sem deploy.
REMINDER_JOB_INTERVAL_MS=900000

# ─── Logs ────────────────────────────────────────────────────────────────────
# Níveis: trace | debug | info | warn | error | silent
LOG_LEVEL=info

# ─── Sentry (opcional) ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Taxa de amostragem de tracing (0 = desativado, 0.1 = 10% das requests)
SENTRY_TRACES_SAMPLE_RATE=0

# ─── Observability / Métricas Prometheus ──────────────────────────────────────
# Token para proteger o endpoint /metrics (Bearer auth). Deixe vazio para acesso livre.
METRICS_TOKEN=
# Intervalo de refresh das métricas de outbox/pool/redis (ms)
METRICS_REFRESH_MS=15000

# ─── Debug ───────────────────────────────────────────────────────────────────
DEBUG_PLAN=false

# ─── Variáveis encontradas no código — preencher se necessário ───────────────
# Usado em alguns flows de aprovação de acesso
ADMIN_APPROVAL_PIN=
# Aliases alternativos lidos em algumas rotas (verificar uso real)
API_URL=
APP_URL=
# Email de teste para receber cópias em dev
EMAIL_TEST_TO=
TEST_EMAIL_TO=
# Força falha de email em testes (true/false)
MOCK_EMAIL_FAIL=false
# Endereço remetente alternativo Resend
RESEND_FROM_EMAIL=
RESEND_TEST_EMAIL=
# Nome do serviço para logs estruturados
SERVICE_NAME=multgestor-backend
# Bucket Supabase Storage (alias para ICE_BUCKET)
SUPABASE_BUCKET=barber-collaborators
SUPABASE_STORAGE_BUCKET=barber-collaborators

# IA Operacional (Fase 1) — LlmService (backend/src/services/llm)
# Sem LLM_PROVIDER (ou valor invalido), o default e sempre "mock" — nunca
# chama API externa, nao precisa de API key.
LLM_PROVIDER=mock
LLM_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
NVIDIA_API_KEY=
NVIDIA_MODEL=
# Wrappers de custo/seguranca — opcionais, so ativam se preenchidos
LLM_MAX_TOKENS_PER_SESSION=
LLM_MAX_COST_PER_SESSION=
LLM_RATE_PER_TOKEN=
LLM_RATE_LIMIT_MAX_CALLS=
LLM_RATE_LIMIT_WINDOW_MS=
LLM_CIRCUIT_FAILURE_THRESHOLD=
LLM_CIRCUIT_RESET_TIMEOUT_MS=
